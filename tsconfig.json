{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "src",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "noEmitOnError": false,
  },
  "ts-node": {
    "files": true
  },
  "include": ["src/**/*"]
}