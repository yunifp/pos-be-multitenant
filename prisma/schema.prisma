// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum JobPosition {
  OWNER
  MANAGER
  CASHIER
  KITCHEN_STAFF
  WAITER
  BARISTA
  WAREHOUSE_STAFF
}

enum OrderStatus {
  PENDING
  COOKING
  READY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUND_PENDING
  REFUNDED
  PARTIAL
}

// PaymentMethod enum is no longer strictly used for the Order model, 
// but kept for backward compatibility or default seeded values if needed.
enum PaymentMethod {
  CASH
  QRIS
  CARD
  TRANSFER
  MARKETPLACE
  MIDTRANS
  COMPLIMENTARY
}

enum ShiftType {
  MORNING
  NOON
  NIGHT
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  PERMIT
}

enum CashFlowType {
  INCOME_SALES // Pemasukan dari Penjualan
  INCOME_OTHER // Pemasukan lain (Suntikan dana, dll)
  EXPENSE_MATERIAL // Pengeluaran belanja bahan baku
  EXPENSE_OPERATIONAL // Pengeluaran operasional (listrik, gaji)
  EXPENSE_OTHER // Pengeluaran lain-lain
}

enum PromotionType {
  TRANSACTION
  PRODUCT_DISCOUNT
  BUNDLE
}

enum OrderType {
  DINE_IN
  TAKE_HOME
  ONLINE
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PointType {
  EARNED
  REDEEMED
  REFUNDED
  ADJUSTMENT
}

// Format Dokumen
enum DocumentFormat {
  RECEIPT
  INVOICE
}

// Status Distribusi
enum DistributionStatus {
  DRAFT
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

// Mode Pembayaran
enum PaymentChannel {
  BASIC
  GATEWAY
}

// ==========================================
// 1. SAAS MULTI-TENANT CORE (Control Plane Sync)
// ==========================================

model Tenant {
  id       String  @id @default(uuid())
  name     String // Nama Perusahaan/Bisnis
  email    String  @unique
  phone    String?
  isActive Boolean @default(true) @map("is_active")

  // Sinkronisasi dengan Control Plane Eksternal
  externalPlanId String?  @map("external_plan_id")
  activeFeatures String[] @map("active_features") // Cache array fitur (contoh: ["INVENTORY", "QUEUE"])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relasi ke Data Milik Tenant
  branches       Branch[]
  users          User[]
  roles          Role[]
  categories     Category[]
  materials      Material[]
  warehouses     Warehouse[]
  generalSetting GeneralSetting?
  products       Product[]

  @@map("tenants")
}

// ==========================================
// 2. DYNAMIC RBAC (Role-Based Access Control)
// ==========================================

model Role {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  name        String // cth: "Super Admin", "Kasir Reguler", "Manager Gudang"
  description String?

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  module      String // cth: "INVENTORY", "FINANCE", "ORDER"
  action      String // cth: "CREATE", "READ", "UPDATE", "DELETE"
  code        String  @unique // cth: "INVENTORY_CREATE"
  description String?

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ==========================================
// 3. SETTING & CABANG
// ==========================================

model GeneralSetting {
  id                String  @id @default(uuid())
  tenantId          String  @unique @map("tenant_id")
  appName           String  @default("EPS POS") @map("app_name")
  storeName         String  @map("store_name")
  logoUrl           String? @map("logo_url")
  taxRate           Decimal @default(0) @map("tax_rate") @db.Decimal(5, 2)
  serviceChargeRate Decimal @default(0) @map("service_charge_rate") @db.Decimal(5, 2)
  currencySymbol    String  @default("Rp") @map("currency_symbol")

  // Loyalti
  pointsPerAmount Int @default(10000)
  pointValue      Int @default(1)

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt

  @@map("general_settings")
}

model Branch {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  name     String
  address  String?
  phone    String?

  // Fitur Antrian (Req 6)
  enableOrderQueue Boolean @default(true) @map("enable_order_queue")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users                 User[]
  products              Product[]
  branchMaterialStocks  BranchMaterialStock[]
  orders                Order[]
  cashFlows             CashFlow[]
  receiptSetting        ReceiptSetting?
  paymentIntegration    PaymentIntegration?
  incomingDistributions MaterialDistribution[] @relation("DestinationBranch")
  shifts                Shift[]
  branchPaymentMethods  BranchPaymentMethod[] // Relasi baru untuk metode pembayaran cabang

  availablePromos Promotion[] @relation("PromoAvailability")
  members         Member[]

  @@map("branches")
}

model ReceiptSetting {
  id       String @id @default(uuid())
  branchId String @unique @map("branch_id")

  // Fitur Struk / Invoice (Req 5)
  documentFormat     DocumentFormat @default(RECEIPT) @map("document_format")
  invoicePrefix      String?        @map("invoice_prefix") // Jika INVOICE, cth: "INV-"
  dueDaysDefault     Int            @default(0) @map("due_days_default") // Jatuh tempo invoice
  termsAndConditions String?        @map("terms_and_conditions") @db.Text

  storeName     String? @map("store_name")
  footerMessage String? @map("footer_message")
  paperWidth    Int     @default(58) @map("paper_width")

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("receipt_settings")
}

model PaymentIntegration {
  id       String @id @default(uuid())
  branchId String @unique @map("branch_id")

  // Fitur Gateway Midtrans (Req 7)
  channelType       PaymentChannel @default(BASIC) @map("channel_type")
  midtransServerKey String?        @map("midtrans_server_key")
  midtransClientKey String?        @map("midtrans_client_key")
  isProduction      Boolean        @default(false) @map("is_production")

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("payment_integrations")
}

// Model baru untuk konfigurasi metode pembayaran per cabang
model BranchPaymentMethod {
  id       String         @id @default(uuid())
  branchId String         @map("branch_id")
  name     String // Contoh: "QRIS", "Transfer Bank", "Tunai"
  channel  PaymentChannel @default(BASIC) // BASIC (Manual) atau GATEWAY

  // Konfigurasi Biaya (Fee)
  feePercentage Decimal @default(0) @db.Decimal(5, 2) // Contoh: 0.7 untuk QRIS (0.7%)
  feeFlat       Decimal @default(0) @db.Decimal(15, 2) // Contoh: 4500 untuk VA

  isActive Boolean @default(true) @map("is_active")

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, name])
  @@map("branch_payment_methods")
}

model User {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")
  roleId   String  @map("role_id") // Relasi RBAC

  email        String      @unique
  passwordHash String      @map("password_hash")
  fullName     String      @map("full_name")
  jobPosition  JobPosition @default(CASHIER) @map("job_position")
  isActive     Boolean     @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id])
  role   Role    @relation(fields: [roleId], references: [id])

  orders               Order[]
  cashFlows            CashFlow[]
  distributionsCreated MaterialDistribution[]
  attendances          Attendance[]
  assignedShifts       EmployeeShift[]
  requestedRefunds     RefundRequest[]        @relation("RequestedRefunds")
  approvedRefunds      RefundRequest[]        @relation("ApprovedRefunds")

  @@map("users")
}

// ==========================================
// 4. INVENTORY & GUDANG (Req 2 & 3)
// ==========================================

model Warehouse {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  name     String // cth: "Gudang Utama Pusat"
  address  String?

  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stocks                WarehouseStock[]
  outgoingDistributions MaterialDistribution[] @relation("SourceWarehouse")

  @@map("warehouses")
}

model Material {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  name        String // cth: "Biji Kopi Arabica", "Susu UHT"
  unit        String // cth: "Gram", "Liter", "Pcs"
  costPerUnit Decimal @default(0) @map("cost_per_unit") @db.Decimal(15, 2)

  tenant            Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouseStocks   WarehouseStock[]
  branchStocks      BranchMaterialStock[]
  recipes           Recipe[]
  distributionItems MaterialDistributionItem[]

  @@map("materials")
}

model WarehouseStock {
  id          String  @id @default(uuid())
  warehouseId String  @map("warehouse_id")
  materialId  String  @map("material_id")
  quantity    Decimal @default(0) @db.Decimal(15, 3)

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  material  Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, materialId])
  @@map("warehouse_stocks")
}

model BranchMaterialStock {
  id         String  @id @default(uuid())
  branchId   String  @map("branch_id")
  materialId String  @map("material_id")
  quantity   Decimal @default(0) @db.Decimal(15, 3) // Stok di cabang

  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([branchId, materialId])
  @@map("branch_material_stocks")
}

// Distribusi Gudang Pusat ke Cabang
model MaterialDistribution {
  id                String             @id @default(uuid())
  sourceWarehouseId String             @map("source_warehouse_id")
  destBranchId      String             @map("dest_branch_id")
  createdById       String             @map("created_by_id")
  status            DistributionStatus @default(DRAFT)
  notes             String?
  createdAt         DateTime           @default(now()) @map("created_at")
  dispatchedAt      DateTime?          @map("dispatched_at")
  receivedAt        DateTime?          @map("received_at")

  sourceWarehouse Warehouse                  @relation("SourceWarehouse", fields: [sourceWarehouseId], references: [id])
  destBranch      Branch                     @relation("DestinationBranch", fields: [destBranchId], references: [id])
  createdBy       User                       @relation(fields: [createdById], references: [id])
  items           MaterialDistributionItem[]

  @@map("material_distributions")
}

model MaterialDistributionItem {
  id             String  @id @default(uuid())
  distributionId String  @map("distribution_id")
  materialId     String  @map("material_id")
  quantity       Decimal @db.Decimal(15, 3)

  distribution MaterialDistribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  material     Material             @relation(fields: [materialId], references: [id])

  @@map("material_distribution_items")
}

// ==========================================
// 5. PRODUK & RESEP (BOM) (Req 3)
// ==========================================

model Category {
  id       Int     @id @default(autoincrement())
  tenantId String  @map("tenant_id")
  name     String
  isActive Boolean @default(true) @map("is_active")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@map("categories")
}

model Product {
  id         Int     @id @default(autoincrement())
  tenantId   String  @map("tenant_id")
  branchId   String? @map("branch_id") // Null jika produk global untuk semua cabang
  categoryId Int     @map("category_id")
  name       String

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch?          @relation(fields: [branchId], references: [id])
  category Category         @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]

  @@map("products")
}

model ProductVariant {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  name      String
  price     Decimal @db.Decimal(10, 2)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  recipes    Recipe[] // Relasi ke bahan baku

  promotionTargets PromotionTarget[]

  @@map("product_variants")
}

// Resep/BOM: Pengurangan otomatis bahan baku cabang saat varian terjual
model Recipe {
  id               String  @id @default(uuid())
  variantId        Int     @map("variant_id")
  materialId       String  @map("material_id")
  quantityRequired Decimal @map("quantity_required") @db.Decimal(15, 3) // cth: 15 Gram kopi

  variant  ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  material Material       @relation(fields: [materialId], references: [id])

  @@unique([variantId, materialId])
  @@map("recipes")
}

// ==========================================
// 6. TRANSAKSI (POS CORE)
// ==========================================

model Order {
  id            String @id @default(uuid())
  branchId      String @map("branch_id")
  cashierId     String @map("cashier_id")
  invoiceNumber String @unique @map("invoice_number")

  subtotal    Decimal @db.Decimal(15, 2)
  tax         Decimal @default(0) @db.Decimal(15, 2)
  totalAmount Decimal @db.Decimal(15, 2)

  // Perubahan untuk Payment Method Dinamis dan MDR Fee
  paymentMethod  String?        @map("payment_method") // Tipe dirubah dari PaymentMethod enum ke String
  paymentChannel PaymentChannel @default(BASIC) @map("payment_channel") // Menandakan Manual atau Gateway
  paymentFee     Decimal        @default(0) @map("payment_fee") @db.Decimal(15, 2) // Total biaya MDR yang dibebankan

  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")
  status        OrderStatus   @default(PENDING)

  orderType OrderType @default(DINE_IN) @map("order_type")

  // Midtrans Tracking
  midtransTransactionId String? @map("midtrans_transaction_id")

  memberId String? @map("member_id")

  createdAt DateTime @default(now()) @map("created_at")

  branch        Branch         @relation(fields: [branchId], references: [id])
  cashier       User           @relation(fields: [cashierId], references: [id])
  items         OrderItem[]
  refundRequest RefundRequest?

  member            Member?              @relation(fields: [memberId], references: [id])
  appliedPromotions OrderPromotion[]
  pointHistories    MemberPointHistory[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  variantId Int     @map("variant_id")
  quantity  Int
  price     Decimal @db.Decimal(15, 2)
  subtotal  Decimal @db.Decimal(15, 2)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

// ==========================================
// 7. KEUANGAN (Req 4)
// ==========================================

model CashFlow {
  id          String       @id @default(uuid())
  branchId    String       @map("branch_id")
  amount      Decimal      @db.Decimal(15, 2)
  type        CashFlowType // Membedakan Pemasukan vs HPP Belanja vs Operasional
  category    String? // cth: "Beli Biji Kopi", "Bayar Listrik"
  description String?

  // Referensi ke Order ID (jika pendapatan) atau Distribution ID (jika belanja masuk)
  referenceId String? @map("reference_id")

  date       DateTime @default(now())
  recordedBy String   @map("recorded_by")

  branch   Branch @relation(fields: [branchId], references: [id])
  recorder User   @relation(fields: [recordedBy], references: [id])

  @@index([branchId, type, date])
  @@map("cash_flows")
}

model Shift {
  id        String    @id @default(uuid())
  branchId  String    @map("branch_id")
  name      String
  type      ShiftType @default(MORNING)
  startTime String    @map("start_time")
  endTime   String    @map("end_time")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch      Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  assignments EmployeeShift[]

  @@map("shifts")
}

model EmployeeShift {
  id      String   @id @default(uuid())
  userId  String   @map("user_id")
  shiftId String   @map("shift_id")
  date    DateTime @db.Date

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("employee_shifts")
}

model Attendance {
  id         String           @id @default(uuid())
  userId     String           @map("user_id")
  clockIn    DateTime         @map("clock_in")
  clockOut   DateTime?        @map("clock_out")
  date       DateTime         @db.Date
  shiftStart String           @map("shift_start")
  shiftEnd   String           @map("shift_end")
  status     AttendanceStatus @default(PRESENT)
  photoUrl   String?          @map("photo_url")
  location   String?
  notes      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, clockIn])
  @@map("attendances")
}

// ==========================================
// 9. REFUND MANAGEMENT (Fase 4)
// ==========================================

model RefundRequest {
  id            String       @id @default(uuid())
  orderId       String       @unique @map("order_id")
  requestedById String       @map("requested_by_id")
  approvedById  String?      @map("approved_by_id")
  reason        String
  amount        Decimal      @db.Decimal(15, 2)
  status        RefundStatus @default(PENDING)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  order       Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  requestedBy User  @relation("RequestedRefunds", fields: [requestedById], references: [id])
  approvedBy  User? @relation("ApprovedRefunds", fields: [approvedById], references: [id])

  @@map("refund_requests")
}

model Promotion {
  id          String        @id @default(uuid())
  name        String
  code        String        @unique
  type        PromotionType @default(TRANSACTION)
  discountPct Int?          @map("discount_pct")
  discountAmt Decimal?      @map("discount_amt") @db.Decimal(15, 2)
  minPurchase Decimal?      @default(0) @map("min_purchase") @db.Decimal(15, 2)
  maxDiscount Decimal?      @map("max_discount") @db.Decimal(15, 2)
  startDate   DateTime      @map("start_date")
  endDate     DateTime      @map("end_date")
  isActive    Boolean       @default(true) @map("is_active")
  isGlobal    Boolean       @default(false) @map("is_global")
  deletedAt   DateTime?     @map("deleted_at")

  branches       Branch[]          @relation("PromoAvailability")
  targets        PromotionTarget[]
  OrderPromotion OrderPromotion[]

  @@index([code])
  @@map("promotions")
}

model PromotionTarget {
  id          String @id @default(uuid())
  promotionId String @map("promotion_id")
  variantId   Int    @map("variant_id")
  quantity    Int    @default(1)

  promotion Promotion      @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@map("promotion_targets")
}

model OrderPromotion {
  id             String  @id @default(uuid())
  orderId        String  @map("order_id")
  promotionId    String  @map("promotion_id")
  discountAmount Decimal @map("discount_amount") @db.Decimal(15, 2)

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  promotion Promotion @relation(fields: [promotionId], references: [id])

  @@map("order_promotions")
}

// ==========================================
// 11. CRM & MEMBER (Fase 5)
// ==========================================
model Member {
  id       String  @id @default(uuid())
  branchId String  @map("branch_id")
  name     String
  phone    String  @unique
  email    String?
  points   Int     @default(0)

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  branch         Branch               @relation(fields: [branchId], references: [id])
  orders         Order[]
  pointHistories MemberPointHistory[]

  @@index([phone])
  @@map("members")
}

model MemberPointHistory {
  id          String    @id @default(uuid())
  memberId    String    @map("member_id")
  orderId     String?   @map("order_id")
  type        PointType
  amount      Int
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id])

  @@map("member_point_histories")
}
