// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum Role {
  OWNER
  MANAGER
  CASHIER
  KITCHEN
  WAITER
}

enum OrderStatus {
  PENDING
  COOKING
  READY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUND_PENDING
  REFUNDED
  PARTIAL
}

enum PaymentMethod {
  CASH
  QRIS
  CARD
  TRANSFER
  MARKETPLACE
  MIDTRANS
  COMPLIMENTARY
}

enum ShiftType {
  MORNING
  NOON
  NIGHT
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  PERMIT
}

enum CashFlowType {
  INCOME
  EXPENSE
  OPERATIONAL
}

enum PromotionType {
  TRANSACTION
  PRODUCT_DISCOUNT
  BUNDLE
}

enum OrderType {
  DINE_IN
  TAKE_HOME
  ONLINE
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PointType {
  EARNED    // Mendapatkan poin dari belanja
  REDEEMED  // Menggunakan poin untuk diskon
  REFUNDED  // Poin dikembalikan karena refund
  ADJUSTMENT // Koreksi manual oleh admin
}

// --- 1. SETTING & CABANG ---

model GeneralSetting {
  id                   Int      @id @default(1)
  appName              String   @default("EPS POS") @map("app_name")
  tagline              String?  @map("tagline")
  storeName            String   @default("EPISODE KOPI") @map("store_name")
  logoUrl              String?  @map("logo_url")
  loginBgUrl           String?  @map("login_bg_url")
  themePrimaryColor    String   @default("#4F46E5") @map("theme_primary_color")
  themeSecondaryColor  String   @default("#0F172A") @map("theme_secondary_color")
  themeBackgroundColor String   @default("#F3F4F6") @map("theme_background_color")
  taxRate              Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 2)
  serviceChargeRate    Decimal  @default(0) @map("service_charge_rate") @db.Decimal(5, 2)
  currencySymbol       String   @default("Rp") @map("currency_symbol")
  address              String?
  phone                String?
  email                String?
  website              String?

  pointsPerAmount   Int     @default(10000) // Contoh: 10.000
  pointsEarned      Int     @default(1)     // Dapatkan 1 point
  pointValue        Int     @default(1)     // 1 point = Rp 1
  minOrderToEarn    Float   @default(0)     // Minimal belanja untuk dapat poin
  maxRedeemPercent  Int     @default(50)    // Maksimal poin tutup 50% total bill
  isActive          Boolean @default(true)  // Apakah program poin aktif

  updatedAt            DateTime @updatedAt

  @@map("general_settings")
}

model ReceiptSetting {
  id                String   @id @default(uuid())
  branchId          String   @unique @map("branch_id")
  
  // --- Identitas Visual ---
  showLogo          Boolean  @default(true) @map("show_logo")
  logoSize          Int      @default(80) @map("logo_size") // Dalam pixel atau persentase
  grayscaleLogo     Boolean  @default(true) @map("grayscale_logo")
  
  // --- Header Teks ---
  storeName         String?  @map("store_name") // Override nama store jika perlu
  headerAddress     String?  @map("header_address") @db.Text
  headerPhone       String?  @map("header_phone")
  headerEmail       String?  @map("header_email")
  headerWebsite     String?  @map("header_website")
  headerTaxId       String?  @map("header_tax_id") // NPWP Store
  
  // --- Informasi Transaksi ---
  showCashierName   Boolean  @default(true) @map("show_cashier_name")
  showCustomerName  Boolean  @default(true) @map("show_customer_name")
  showOrderType     Boolean  @default(true) @map("show_order_type") // Dine In/Take Away
  showTableNumber   Boolean  @default(true) @map("show_table_number")
  
  // --- Pengaturan Item ---
  showVariantName   Boolean  @default(true) @map("show_variant_name")
  showItemSku       Boolean  @default(false) @map("show_item_sku")
  showItemDiscount  Boolean  @default(true) @map("show_item_discount")
  showItemNotes     Boolean  @default(true) @map("show_item_notes")
  compactMode       Boolean  @default(false) @map("compact_mode") // Baris lebih rapat
  
  // --- Pengaturan Footer & Tambahan ---
  footerMessage     String?  @map("footer_message") @db.Text
  showSocialMedia   Boolean  @default(false) @map("show_social_media")
  instagramHandle   String?  @map("instagram_handle")
  
  // --- Kebijakan & Promo ---
  showPointsEarned  Boolean  @default(true) @map("show_points_earned")
  showBarcode       Boolean  @default(true) @map("show_barcode") // Scan barcode untuk invoice
  isRefundPolicy    String?  @map("refund_policy") @db.Text // Teks kebijakan pengembalian
  
  // --- Format Teknis ---
  paperWidth        Int      @default(58) @map("paper_width") // 58mm atau 80mm
  fontSize          String   @default("MEDIUM") @map("font_size") // SMALL, MEDIUM, LARGE
  fontFamily        String   @default("Monospace") @map("font_family")
  
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  branch            Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("receipt_settings")
}
model Branch {
  id        String    @id @default(uuid())
  name      String
  address   String?
  phone     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // [BARU] Geofencing Data
  latitude  Float @default(0) // Contoh: -6.175392
  longitude Float @default(0) // Contoh: 106.827153
  radius    Int   @default(50) // Toleransi dalam meter (misal 50 meter)

  // Relations
  users               User[]
  availableCategories Category[]       @relation("CategoryAvailability")
  products            Product[] // [FIXED] Nama relasi disederhanakan
  availablePromos     Promotion[]      @relation("PromoAvailability")
  productStocks       ProductStock[]
  orders              Order[]
  cashFlows           CashFlow[]
  inventoryStocks     InventoryStock[]
  shifts              Shift[]
  members             Member[]
  receiptSetting    ReceiptSetting?

  @@map("branches")
}

model User {
  id           String    @id @default(uuid())
  branchId     String?   @map("branch_id")
  email        String    @unique
  passwordHash String    @map("password_hash")
  pinHash      String?   @map("pin_hash")
  fullName     String    @map("full_name")
  role         Role      @default(CASHIER)
  phone        String?
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  branch         Branch?         @relation(fields: [branchId], references: [id])
  orders         Order[]         @relation("CashierOrders")
  cashFlows      CashFlow[]      @relation("CashFlowRecorder")
  attendances    Attendance[]
  assignedShifts EmployeeShift[]
  requestedRefunds RefundRequest[] @relation("RequestedRefunds")
  approvedRefunds  RefundRequest[] @relation("ApprovedRefunds")

  @@index([branchId])
  @@map("users")
}

// --- 2. PRODUK & KATEGORI ---

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  isGlobal  Boolean   @default(false) @map("is_global")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  branches Branch[]  @relation("CategoryAvailability")
  products Product[]

  @@map("categories")
}

model Product {
  id Int @id @default(autoincrement())

  // [FIXED] Tipe data diubah ke String agar cocok dengan Branch.id (UUID)
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  name        String
  description String?
  image       String?
  hasVariants Boolean          @default(false)
  variants    ProductVariant[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  deletedAt DateTime? @map("deleted_at")

  @@map("products")
}

model ProductVariant {
  id          Int      @id @default(autoincrement())
  productId   Int
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String
  price       Decimal  @db.Decimal(10, 2)
  hpp         Decimal  @default(0) @db.Decimal(15, 2)
  sku         String?
  manageStock Boolean  @default(true)
  stock       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // [FIXED] Menambahkan relasi balik (Opposite Relations)
  stocks           ProductStock[]
  promotionTargets PromotionTarget[]
  orderItems       OrderItem[]

  @@map("product_variants")
}

model ProductStock {
  id       String @id @default(uuid())
  branchId String @map("branch_id")

  // [FIXED] Tipe data diubah ke Int agar cocok dengan ProductVariant.id
  variantId Int @map("variant_id")

  quantity  Int      @default(0)
  minStock  Int      @default(5) @map("min_stock")
  price     Decimal? @db.Decimal(15, 2)
  hpp       Decimal? @db.Decimal(15, 2)
  updatedAt DateTime @updatedAt

  branch  Branch         @relation(fields: [branchId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([branchId, variantId])
  @@map("product_stocks")
}

// --- 3. PROMOSI ---
model Promotion {
  id          String        @id @default(uuid())
  branchId    String?       @map("branch_id")
  name        String
  code        String        @unique
  type        PromotionType @default(TRANSACTION)
  discountPct Int?          @map("discount_pct")
  discountAmt Decimal?      @map("discount_amt") @db.Decimal(15, 2)
  minPurchase Decimal?      @default(0) @map("min_purchase") @db.Decimal(15, 2)
  maxDiscount Decimal?      @map("max_discount") @db.Decimal(15, 2)
  startDate   DateTime      @map("start_date")
  endDate     DateTime      @map("end_date")
  isActive    Boolean       @default(true) @map("is_active")
  isGlobal    Boolean       @default(false) @map("is_global")
  deletedAt   DateTime?     @map("deleted_at")

  branches       Branch[]          @relation("PromoAvailability")
  targets        PromotionTarget[]
  OrderPromotion OrderPromotion[]

  @@index([code])
  @@map("promotions")
}

model PromotionTarget {
  id          String @id @default(uuid())
  promotionId String @map("promotion_id")

  // [FIXED] Tipe data diubah ke Int agar cocok dengan ProductVariant.id
  variantId Int @map("variant_id")

  quantity Int @default(1)

  promotion Promotion      @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@map("promotion_targets")
}


model RefundRequest {
  id           String   @id @default(uuid())
  orderId      String   @unique @map("order_id")
  requestedById String   @map("requested_by_id")
  approvedById  String?  @map("approved_by_id")
  reason       String
  amount       Decimal  @db.Decimal(15, 2)
  status       RefundStatus @default(PENDING)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  order        Order    @relation(fields: [orderId], references: [id])
  requestedBy  User     @relation("RequestedRefunds", fields: [requestedById], references: [id])
  approvedBy   User?    @relation("ApprovedRefunds", fields: [approvedById], references: [id])

  @@map("refund_requests")
}

// --- 4. TRANSAKSI (POS CORE) ---
model Order {
  id            String         @id @default(uuid())
  branchId      String         @map("branch_id")
  cashierId     String         @map("cashier_id")
  memberId      String?        @map("member_id")
  invoiceNumber String         @unique @map("invoice_number")
  subtotal      Decimal        @db.Decimal(15, 2)
  tax           Decimal        @default(0) @db.Decimal(15, 2)
  serviceCharge Decimal        @default(0) @map("service_charge") @db.Decimal(15, 2)
  discount      Decimal        @default(0) @db.Decimal(15, 2)
  totalAmount   Decimal        @db.Decimal(15, 2)
  paymentMethod PaymentMethod? @map("payment_method")
  paymentStatus PaymentStatus  @default(UNPAID) @map("payment_status")
  status        OrderStatus    @default(PENDING)
  notes         String?

  orderType    OrderType @default(DINE_IN)
  platformName String? // Untuk menyimpan "Gofood", "Grabfood", dll
  customerName String? // Nama untuk Open Ticket

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branch  Branch      @relation(fields: [branchId], references: [id])
  cashier User        @relation("CashierOrders", fields: [cashierId], references: [id])
  member  Member?     @relation(fields: [memberId], references: [id])
  items   OrderItem[]

  appliedPromotions OrderPromotion[]

  refundRequest RefundRequest?

  pointHistories MemberPointHistory[]

  @@index([branchId])
  @@index([createdAt])
  @@index([status])
  @@index([paymentStatus])
  @@map("orders")
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String @map("order_id")

  // [FIXED] Tipe data diubah ke Int agar cocok dengan ProductVariant.id
  variantId Int @map("variant_id")

  quantity Int
  price    Decimal @db.Decimal(15, 2)
  hpp      Decimal @default(0) @db.Decimal(15, 2)
  discount Decimal @default(0) @db.Decimal(15, 2)
  subtotal Decimal @db.Decimal(15, 2)
  notes    String? @map("notes")

  isReady   Boolean @default(false) @map("is_ready")
  
  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model OrderPromotion {
  id          String @id @default(uuid())
  orderId     String @map("order_id")
  promotionId String @map("promotion_id")

  // Mencatat nominal diskon yang disumbangkan oleh promo ini khusus untuk order ini
  discountAmount Decimal @map("discount_amount") @db.Decimal(15, 2)

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  promotion Promotion @relation(fields: [promotionId], references: [id])

  @@map("order_promotions")
}

// --- 5. INVENTARIS (BAHAN BAKU) ---
model InventoryItem {
  id       String           @id @default(uuid())
  name     String
  unit     String
  minStock Int              @default(5) @map("min_stock")
  stocks   InventoryStock[]

  @@map("inventory_items")
}

model InventoryStock {
  id       String  @id @default(uuid())
  branchId String  @map("branch_id")
  itemId   String  @map("item_id")
  quantity Decimal @db.Decimal(10, 2)

  branch Branch        @relation(fields: [branchId], references: [id])
  item   InventoryItem @relation(fields: [itemId], references: [id])

  @@unique([branchId, itemId])
  @@map("inventory_stocks")
}

// --- 6. CRM (MEMBER) ---
model Member {
  id     String  @id @default(uuid())
  name   String
  phone  String  @unique
  email  String?
  points Int     @default(0)

  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id])

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  orders    Order[]
  pointHistories MemberPointHistory[]

  @@index([phone])
  @@map("members")
}

// Riwayat Poin untuk Audit
model MemberPointHistory {
  id        String    @id @default(uuid())
  memberId  String    @map("member_id")
  orderId   String?   @map("order_id")
  type      PointType
  amount    Int       // Jumlah poin yang masuk/keluar
  description String?
  createdAt DateTime  @default(now()) @map("created_at")

  member    Member    @relation(fields: [memberId], references: [id])
  order     Order?    @relation(fields: [orderId], references: [id])

  @@map("member_point_histories")
}

// --- 7. HR & SHIFT ---
model Shift {
  id        String    @id @default(uuid())
  branchId  String    @map("branch_id")
  name      String // Contoh: "Shift Pagi"
  type      ShiftType @default(MORNING)
  startTime String    @map("start_time") // Format "HH:mm"
  endTime   String    @map("end_time") // Format "HH:mm"

  branch      Branch          @relation(fields: [branchId], references: [id])
  assignments EmployeeShift[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("shifts")
}

model EmployeeShift {
  id      String   @id @default(uuid())
  userId  String   @map("user_id")
  shiftId String   @map("shift_id")
  date    DateTime @db.Date // Hanya tanggal (tanpa jam)

  user  User  @relation(fields: [userId], references: [id])
  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  // CONSTRAINT: Satu user hanya boleh punya 1 jadwal di tanggal yang sama
  @@unique([userId, date])
  @@map("employee_shifts")
}

model Attendance {
  id       String           @id @default(uuid())
  userId   String           @map("user_id")
  clockIn  DateTime         @map("clock_in")
  clockOut DateTime?        @map("clock_out")
  status   AttendanceStatus @default(PRESENT)
  photoUrl String?          @map("photo_url")
  location String? // Lat,Long atau Nama Tempat
  notes    String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, clockIn])
  @@map("attendances")
}

// --- 8. KEUANGAN ---
model CashFlow {
  id          String       @id @default(uuid())
  branchId    String       @map("branch_id")
  amount      Decimal      @db.Decimal(15, 2)
  type        CashFlowType
  category    String?
  description String?
  receiptUrl  String?      @map("receipt_url")
  date        DateTime     @default(now())
  recordedBy  String       @map("recorded_by")

  branch   Branch @relation(fields: [branchId], references: [id])
  recorder User   @relation("CashFlowRecorder", fields: [recordedBy], references: [id])

  @@index([branchId, date])
  @@map("cash_flows")
}
